# Environment overrides for local development.
# These are NOT loaded automatically — copy to .env and use python-dotenv if needed.

# Override config file path
# NEXUSGATE_CONFIG=./config.toml

# Override log level without editing config
# NEXUSGATE_LOG_LEVEL=DEBUG

# Database URLs (can override config.toml per-alias via env)
# DATABASE_MAIN_DB_URL=sqlite:///./data/main.db
# DATABASE_ANALYTICS_URL=postgresql://user:pass@localhost:5432/analytics

# Redis (for cache and rate limiting backends)
# REDIS_URL=redis://localhost:6379/0
