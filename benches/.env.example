# ─────────────────────────────────────────────────────────────────────────────
# NexusGate Benchmark Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to the project root as `.env` and fill in your values.
# Then run:  python benches/bench_db.py
#
# Usage with inline CLI args (overrides .env):
#   python benches/bench_db.py <BEARER_TOKEN> [concurrency] [total_requests]
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the running NexusGate server
API_URL=http://127.0.0.1:4500

# API Key — Base64-encoded "name:secret" from config.toml
# Example: echo -n "admin:ZvLpwTTx..." | base64
API_KEY=

# Target database name (as defined in config.toml [database.*])
DB_NAME=main_db

# Target filesystem alias (as defined in config.toml [storage.*])
FS_ALIAS=local_fs

# Benchmark load parameters
CONCURRENCY=50
TOTAL_REQUESTS=500
